# Aura — Environment Configuration
# Copy this to .env and fill in real values

# Google Cloud
GOOGLE_CLOUD_PROJECT=ai-agent-labs-oslo-26-team-6
GOOGLE_CLOUD_LOCATION=europe-north1

# Tell google-adk to use Vertex AI instead of AI Studio
GOOGLE_GENAI_USE_VERTEXAI=1

# If running locally without Application Default Credentials,
# set the path to your service account key:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# App
APP_NAME=aura
PORT=8080

# Integration mode
# mock = in-repo deterministic tools (default)
# real = external API adapters (requires URLs/tokens below)
AURA_PROVIDER_MODE=mock

# UCP (required in real mode)
# UCP_DISCOVERY_URL=https://registry.ucp.example/vendors

# BMS Compliance (required in real mode)
# BMS_COMPLIANCE_URL=https://bms.example/api/compliance/verify
# BMS_COMPLIANCE_TOKEN=<optional-token>

# AP2 (required in real mode)
# AP2_MANDATE_URL=https://ap2.example/api/mandates
# AP2_SETTLEMENT_URL=https://ap2.example/api/settlements
# AP2_API_TOKEN=<optional-token>

# API Authentication (optional)
# When AUTH_ENABLED=true, /run and /run/stream require a valid JWT bearer token.
AUTH_ENABLED=false
AUTH_JWT_SECRET=
AUTH_JWT_ALGORITHM=HS256
# Comma-separated roles allowed to execute procurement endpoints
AUTH_ALLOWED_ROLES=procurement_runner,admin
